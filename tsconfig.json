{
  "compilerOptions": {
    "target": "ES2021",                    // ES2023 pode ser alto demais dependendo do Node usado
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,               // Recomendado p/ compatibilidade com libs comuns
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,                        // Ativa todas as validações úteis
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strictNullChecks": true,
    "noImplicitAny": false,                // Você já desativou — ok p/ protótipos
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",            // Compatível com importações no Nest
    "resolveJsonModule": true              // Permite importar arquivos .json
  },
  "include": [
    "src/**/*.ts",
    "app.module.ts",
    "app.service.ts",
    "test/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}